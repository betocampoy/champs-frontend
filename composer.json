{
  "name": "betocampoy/champs-frontend",
  "description": "Templates Twig compartilhados e champs-core-js para projetos legados e Symfony.",
  "type": "library",
  "license": "MIT",
  "require": {
    "php": ">=8.1",
    "twig/twig": "^2.12 || ^3.0"
  },
  "autoload": {
    "psr-4": {
      "BetoCampoy\\Champs\\Frontend\\": "src/"
    }
  },
  "bin": [
    "bin/champs-frontend-publish-assets"
  ],
  "scripts": {
    "champs-frontend-publish-assets": [
      "@php vendor/bin/champs-frontend-publish-assets assets/vendor/champs-frontend"
    ]
  }
}
