{# ============================================================
  MACRO: checkbox(cfg)
  Objetivo: checkbox BS5
============================================================ #}
{% macro checkbox(cfg) %}
    {% import _self as ui %}

    {% set col = cfg.col|default('col-12') %}
    {% set wrapperClasses = cfg.wrapperClasses|default('') %}
    {% set id = cfg.id|default(cfg.name) %}
    {% set label = cfg.label|default('') %}
    {% set checked = cfg.checked|default(false) %}
    {% set disabled = cfg.disabled|default(false) %}
    {% set attrs = cfg.attrs|default({}) %}
    {% set value = cfg.value is defined ? cfg.value : '1' %}
    {% set checkClasses = cfg.checkClasses|default('') %}
    {% set inputClasses = cfg.inputClasses|default('') %}
    {% set labelClasses = cfg.labelClasses|default('') %}

    <div class="{{ col }} {{ wrapperClasses }}">
        <div class="form-check {{ checkClasses }}">
            <input
                    class="form-check-input {{ inputClasses }}"
                    type="checkbox"
                    name="{{ cfg.name }}"
                    id="{{ id }}"
                    value="{{ value }}"
                    {{ checked ? 'checked' : '' }}
                    {{ disabled ? 'disabled' : '' }}
                    {{ ui.attrs(attrs) }}
            >
            <label class="form-check-label {{ labelClasses }}" for="{{ id }}">{{ label }}</label>
        </div>
    </div>
{% endmacro %}


{# ============================================================
  MACRO: radioGroup(cfg)
  Objetivo: grupo de radios
============================================================ #}
{% macro radioGroup(cfg) %}
    {% import _self as ui %}

    {% set col = cfg.col|default('col-12') %}
    {% set wrapperClasses = cfg.wrapperClasses|default('') %}
    {% set name = cfg.name %}
    {% set selected = cfg.selected is defined ? cfg.selected : '' %}
    {% set options = cfg.options|default([]) %}
    {% set itemClasses = cfg.itemClasses|default('') %}
    {% set inputClasses = cfg.inputClasses|default('') %}
    {% set labelClasses = cfg.labelClasses|default('') %}

    <div class="{{ col }} {{ wrapperClasses }}">
        {% for opt in options %}
            {% set value = opt.value is defined ? opt.value : '' %}
            {% set label = opt.label is defined ? opt.label : '' %}
            {% set isChecked = (value ~ '') == (selected ~ '') %}
            {% set itemId = (cfg.idPrefix|default(name)) ~ '_' ~ loop.index %}

            <div class="form-check {{ itemClasses }}">
                <input
                        class="form-check-input {{ inputClasses }}"
                        type="radio"
                        name="{{ name }}"
                        id="{{ itemId }}"
                        value="{{ value }}"
                        {{ isChecked ? 'checked' : '' }}
                >
                <label class="form-check-label {{ labelClasses }}" for="{{ itemId }}">{{ label }}</label>
            </div>
        {% endfor %}
    </div>
{% endmacro %}

{# ============================================================
  MACRO: checkboxCollapseGroup(cfg)
  Objetivo: grupo de checkboxes colapsável (filtro múltiplo elegante)
============================================================ #}
{% macro checkboxCollapseGroup(cfg) %}
    {% import _self as ui %}

    {% set col = cfg.col|default('col-12') %}
    {% set wrapperClasses = cfg.wrapperClasses|default('') %}
    {% set label = cfg.label|default('') %}
    {% set name = cfg.name %}
    {% set fieldName = name ends with '[]' ? name : name ~ '[]' %}
    {% set options = cfg.options|default([]) %}
    {% set selected = cfg.selected|default([]) %}
    {% set collapseId = cfg.id|default(name ~ '_collapse') %}
    {% set help = cfg.help|default(null) %}
    {% set helpClasses = cfg.helpClasses|default('') %}

    <div class="{{ col }} {{ wrapperClasses }}">
        {% if label %}
            <label class="form-label d-flex justify-content-between align-items-center">
                {{ label }}

                <button
                        class="btn btn-sm btn-light border"
                        type="button"
                        data-bs-toggle="collapse"
                        data-bs-target="#{{ collapseId }}"
                        aria-expanded="false"
                >
                    <i class="bi bi-funnel"></i>
                </button>
            </label>
        {% endif %}

        <div class="collapse show" id="{{ collapseId }}">
            <div class="border rounded p-2" style="max-height: 180px; overflow-y: auto;">
                {% for opt in options %}
                    {% set value = opt.value %}
                    {% set optLabel = opt.label %}
                    {% set checked = value in selected %}

                    <div class="form-check">
                        <input
                                class="form-check-input"
                                type="checkbox"
                                name="{{ fieldName }}"
                                value="{{ value }}"
                                id="{{ collapseId }}_{{ loop.index }}"
                                {{ checked ? 'checked' : '' }}
                        >
                        <label class="form-check-label" for="{{ collapseId }}_{{ loop.index }}">
                            {{ optLabel }}
                        </label>
                    </div>
                {% endfor %}
            </div>
        </div>

        {% if help %}
            <div class="form-text {{ helpClasses }}">
                {{ help }}
            </div>
        {% endif %}
    </div>
{% endmacro %}

{# ============================================================
  MACRO: navTabs(cfg)
  Objetivo: gerar <ul class="nav nav-tabs"> (ou pills) para BS5
============================================================ #}
{% macro navTabs(cfg) %}
    {% import _self as ui %}

    {% set id = cfg.id|default('tabs') %}
    {% set tabs = cfg.tabs|default([]) %}
    {% set pills = cfg.pills|default(false) %}
    {% set fill = cfg.fill|default(false) %}
    {% set justified = cfg.justified|default(false) %}
    {% set attrs = cfg.attrs|default({}) %}
    {% set extraClasses = cfg.classes|default('') %}
    {% set itemClasses = cfg.itemClasses|default('') %}
    {% set buttonClasses = cfg.buttonClasses|default('') %}

    <ul
            class="nav {{ pills ? 'nav-pills' : 'nav-tabs' }} {{ fill ? 'nav-fill' : '' }} {{ justified ? 'nav-justified' : '' }} {{ extraClasses }}"
            id="{{ id }}"
            role="tablist"
            {{ ui.attrs(attrs) }}
    >
        {% for t in tabs %}
            {% set key = t.key %}
            {% set label = t.label|default(key) %}
            {% set active = t.active|default(false) %}
            {% set disabled = t.disabled|default(false) %}

            {% set btnId = id ~ '-' ~ key ~ '-tab' %}
            {% set paneId = id ~ '-' ~ key %}

            <li class="nav-item {{ itemClasses }}" role="presentation">
                <button
                        class="nav-link {{ active ? 'active' : '' }} {{ disabled ? 'disabled' : '' }} {{ buttonClasses }}"
                        id="{{ btnId }}"
                        data-bs-toggle="tab"
                        data-bs-target="#{{ paneId }}"
                        type="button"
                        role="tab"
                        aria-controls="{{ paneId }}"
                        aria-selected="{{ active ? 'true' : 'false' }}"
                        {{ disabled ? 'disabled' : '' }}
                >
                    {{ label }}
                </button>
            </li>
        {% endfor %}
    </ul>
{% endmacro %}


{# ============================================================
  MACRO: tabPaneStart(cfg)
  Objetivo: abrir o container do TAB PANE de forma padronizada
============================================================ #}
{% macro tabPaneStart(cfg) %}
    {% import _self as ui %}

    {% set navId = cfg.navId|default('tabs') %}
    {% set key = cfg.key|default('pane') %}
    {% set active = cfg.active|default(false) %}
    {% set extraClasses = cfg.classes|default('') %}
    {% set attrs = cfg.attrs|default({}) %}
    {% set paneId = navId ~ '-' ~ key %}
    {% set tabId = navId ~ '-' ~ key ~ '-tab' %}

<div
        class="tab-pane fade {{ active ? 'show active' : '' }} {{ extraClasses }}"
        id="{{ paneId }}"
        role="tabpanel"
        aria-labelledby="{{ tabId }}"
        tabindex="0"
        {{ ui.attrs(attrs) }}
>
    {% endmacro %}


    {# ============================================================
  MACRO: tabPaneEnd()
  Objetivo: fechar o container do TAB PANE
============================================================ #}
    {% macro tabPaneEnd() %}
</div>
{% endmacro %}