{# templates/ui/_form.html.twig #}

{# ============================================================
  MACRO: attrs(attrs)
  Objetivo: imprimir atributos HTML a partir de um map/dict

  Exemplo:
  {{ ui.attrs({ 'data-x': '1', 'aria-label': 'Teste', disabled: true }) }}

  Resultado:
  data-x="1" aria-label="Teste" disabled
============================================================ #}
{% macro attrs(attrs) %}
    {% for k, v in attrs|default({}) %}
        {% if v is same as(true) %}
            {{- ' ' ~ k -}}
        {% elseif v is not same as(false) and v is not null %}
            {{- ' ' ~ k -}}="{{ v|e('html_attr') }}"
        {% endif %}
    {% endfor %}
{% endmacro %}


{# ============================================================
  MACRO: button(cfg)
  Objetivo: renderizar botão genérico, sem obrigar data-champs-ajax

  Exemplo:
  {{ ui.button({
      classes: 'btn btn-secondary',
      icon: 'bi-gear',
      title: 'Ação local',
      label: 'Executar',
      attrs: {
        onclick: 'acaoLocal(this)',
        'data-id': 10
      }
  }) }}
============================================================ #}
{% macro button(cfg) %}
    {% import _self as ui %}

    {% set type = cfg.type|default('button') %}
    {% set classes = cfg.classes|default('btn btn-primary') %}
    {% set icon = cfg.icon|default(null) %}
    {% set title = cfg.title|default(null) %}
    {% set label = cfg.label|default('') %}
    {% set attrs = cfg.attrs|default({}) %}

    <button
            type="{{ type }}"
            class="{{ classes }}"
            {% if title %}title="{{ title }}"{% endif %}
            {{ ui.attrs(attrs) }}
    >
        {% if icon %}<i class="bi {{ icon }}"></i>{% endif %}
        {{ label }}
    </button>
{% endmacro %}


{# ============================================================
  MACRO: ajaxButton(cfg)
  Objetivo: botão com data-champs-ajax

  Exemplo:
  {{ ui.ajaxButton({
      classes: 'btn btn-primary',
      icon: 'bi-check2',
      title: 'Salvar',
      label: 'Salvar',
      route: 'razoes_sociais-post.php',
      withInputs: true,
      fields: { action: 'update', empresa_id: empresa.id },
      attrs: { 'data-champs-ajax-priorize-data-attr': 'action' }
  }) }}
============================================================ #}
{% macro ajaxButton(cfg) %}
    {% import _self as ui %}

    {% set route = cfg.route|default('') %}
    {% set withInputs = cfg.withInputs|default(false) %}
    {% set fields = cfg.fields|default({}) %}
    {% set attrs = cfg.attrs|default({}) %}

    {% set ajaxAttrs = {
        'data-champs-ajax': true,
        'data-champs-ajax-route': route,
        'data-champs-ajax-with-inputs': withInputs ? 'true' : 'false'
    } %}

    {% for k, v in fields %}
        {% set ajaxAttrs = ajaxAttrs|merge({
            ('data-champs-ajax-field-' ~ k): v
        }) %}
    {% endfor %}

    {{ ui.button(cfg|merge({
        attrs: ajaxAttrs|merge(attrs)
    })) }}
{% endmacro %}


{# ============================================================
  MACRO: renderButton(cfg)
  Objetivo: decidir automaticamente qual macro usar para renderizar
  o botão dentro dos groups.

  mode:
  - ajax   => usa ui.ajaxButton(cfg)
  - button => usa ui.button(cfg)
  - default: button
============================================================ #}
{% macro renderButton(cfg) %}
    {% import _self as ui %}

    {% set mode = cfg.mode|default('button') %}

    {% if mode == 'ajax' %}
        {{ ui.ajaxButton(cfg) }}
    {% else %}
        {{ ui.button(cfg) }}
    {% endif %}
{% endmacro %}


{# ============================================================
  MACRO: input(cfg)
  Objetivo: dispatcher para estilos de input

  style:
  - prefixed (default) => usa inputGroup()
  - inline             => label acima
  - floating           => floating label
============================================================ #}
{% macro input(cfg) %}
    {% import _self as ui %}

    {% set style = cfg.style|default('prefixed') %}

    {% if style == 'floating' %}
        {{ ui.inputFloating(cfg) }}
    {% elseif style == 'inline' %}
        {{ ui.inputInline(cfg) }}
    {% else %}
        {{ ui.inputGroup(cfg) }}
    {% endif %}
{% endmacro %}


{# ============================================================
  MACRO: inputGroup(cfg)
  Objetivo: input com label no input-group + (opcional) botões
============================================================ #}
{% macro inputGroup(cfg) %}
    {% import _self as ui %}

    {% set col = cfg.col|default('col-12') %}
    {% set wrapperClasses = cfg.wrapperClasses|default('') %}
    {% set type = cfg.type|default('text') %}
    {% set id = cfg.id|default(cfg.name) %}
    {% set value = cfg.value is defined ? cfg.value : '' %}
    {% set label = cfg.label|default('') %}
    {% set placeholder = cfg.placeholder|default('') %}
    {% set readonly = cfg.readonly|default(false) %}
    {% set disabled = cfg.disabled|default(false) %}
    {% set required = cfg.required|default(false) %}
    {% set help = cfg.help|default(null) %}
    {% set help_raw = cfg.help_raw|default(false) %}
    {% set attrs = cfg.attrs|default({}) %}
    {% set buttons = cfg.buttons|default([]) %}
    {% set groupClasses = cfg.groupClasses|default('') %}
    {% set labelClasses = cfg.labelClasses|default('') %}
    {% set inputClasses = cfg.inputClasses|default('') %}
    {% set helpClasses = cfg.helpClasses|default('') %}

    <div class="{{ col }} {{ wrapperClasses }}">
        <div class="input-group {{ groupClasses }}">
            {% if label %}
                <span class="input-group-text {{ labelClasses }}">{{ label }}</span>
            {% endif %}

            <input
                    type="{{ type }}"
                    class="form-control {{ inputClasses }}"
                    name="{{ cfg.name }}"
                    id="{{ id }}"
                    value="{{ value }}"
                    placeholder="{{ placeholder }}"
                    {{ readonly ? 'readonly' : '' }}
                    {{ disabled ? 'disabled' : '' }}
                    {{ required ? 'required' : '' }}
                    {{ ui.attrs(attrs) }}
            >

            {% for btn in buttons %}
                {{ ui.renderButton(btn) }}
            {% endfor %}
        </div>

        {% if help %}
            <div class="form-text {{ helpClasses }}">
                {% if help_raw %}
                    {{ help|raw }}
                {% else %}
                    {{ help }}
                {% endif %}
            </div>
        {% endif %}
    </div>
{% endmacro %}


