============================================================ #}
{% macro remoteSelect(cfg) %}
    {% import _self as ui %}

    {% set style = cfg.style|default('prefixed') %}

    {% if style == 'floating' %}
        {{ ui.remoteSelectFloating(cfg) }}
    {% elseif style == 'inline' %}
        {{ ui.remoteSelectInline(cfg) }}
    {% else %}
        {{ ui.remoteSelectGroup(cfg) }}
    {% endif %}
{% endmacro %}


{# ============================================================
  MACRO: remoteSelectGroup(cfg)
  Objetivo: select remoto (TomSelect) disparado por data-champs-remote-select
  Observação: o "value inicial" aqui é uma <option selected>
============================================================ #}
{% macro remoteSelectGroup(cfg) %}
    {% import _self as ui %}

    {% set col = cfg.col|default('col-12') %}
    {% set wrapperClasses = cfg.wrapperClasses|default('') %}
    {% set id = cfg.id|default(cfg.name) %}
    {% set label = cfg.label|default('') %}
    {% set name = cfg.name %}
    {% set required = cfg.required|default(false) %}
    {% set disabled = cfg.disabled|default(false) %}
    {% set help = cfg.help|default(null) %}
    {% set help_raw = cfg.help_raw|default(false) %}
    {% set attrs = cfg.attrs|default({}) %}
    {% set buttons = cfg.buttons|default([]) %}
    {% set groupClasses = cfg.groupClasses|default('') %}
    {% set labelClasses = cfg.labelClasses|default('') %}
    {% set selectClasses = cfg.selectClasses|default('') %}
    {% set helpClasses = cfg.helpClasses|default('') %}

    {% set url = cfg.url|default('') %}
    {% set placeholder = cfg.placeholder|default('') %}
    {% set minChars = cfg.minChars is defined ? cfg.minChars : null %}
    {% set perPage = cfg.perPage is defined ? cfg.perPage : null %}
    {% set allowClear = cfg.allowClear is defined ? cfg.allowClear : null %}

    {% set selectedId = cfg.selectedId is defined ? cfg.selectedId : null %}
    {% set selectedLabel = cfg.selectedLabel is defined ? cfg.selectedLabel : null %}

    <div class="{{ col }} {{ wrapperClasses }}">
        <div class="input-group {{ groupClasses }}">
            {% if label %}
                <span class="input-group-text {{ labelClasses }}">{{ label }}</span>
            {% endif %}

            <select
                    class="form-select {{ selectClasses }}"
                    name="{{ name }}"
                    id="{{ id }}"
                    data-champs-remote-select="true"
                    data-champs-remote-select-url="{{ url }}"
                    {% if placeholder %}data-champs-remote-select-placeholder="{{ placeholder }}"{% endif %}
                    {% if minChars is not null %}data-champs-remote-select-min-chars="{{ minChars }}"{% endif %}
                    {% if perPage is not null %}data-champs-remote-select-per-page="{{ perPage }}"{% endif %}
                    {% if allowClear is not null %}data-champs-remote-select-allow-clear="{{ allowClear ? 'true' : 'false' }}"{% endif %}
                    {{ required ? 'required' : '' }}
                    {{ disabled ? 'disabled' : '' }}
                    {{ ui.attrs(attrs) }}
            >
                {% if selectedId is not null and selectedLabel is not null %}
                    <option value="{{ selectedId }}" selected>{{ selectedLabel }}</option>
                {% else %}
                    <option value=""></option>
                {% endif %}
            </select>

            {% for btn in buttons %}
                {{ ui.renderButton(btn) }}
            {% endfor %}
        </div>

        {% if help %}
            <div class="form-text {{ helpClasses }}">
                {% if help_raw %}
                    {{ help|raw }}
                {% else %}
                    {{ help }}
                {% endif %}
            </div>
        {% endif %}
    </div>
{% endmacro %}


