{% set pageParam = pageParam|default('pagina') %}
{% set maxVisiblePages = maxVisiblePages|default(7) %}

{% if pager and pager.haveToPaginate %}
    {% set currentPage = pager.currentPage %}
    {% set totalPages = pager.nbPages %}

    {% set half = (maxVisiblePages // 2) %}
    {% set startPage = currentPage - half %}
    {% set endPage = currentPage + half %}

    {% if startPage < 1 %}
        {% set endPage = endPage + (1 - startPage) %}
        {% set startPage = 1 %}
    {% endif %}

    {% if endPage > totalPages %}
        {% set startPage = startPage - (endPage - totalPages) %}
        {% set endPage = totalPages %}
    {% endif %}

    {% if startPage < 1 %}
        {% set startPage = 1 %}
    {% endif %}

    <nav aria-label="Paginação" class="mt-4">
        <ul class="pagination pagination-sm justify-content-center flex-wrap mb-0">
            <li class="page-item {{ not pager.hasPreviousPage ? 'disabled' : '' }}">
                {% if pager.hasPreviousPage %}
                    <a class="page-link"
                       href="?{{ pageParam }}=1{% if queryString %}&{{ queryString }}{% endif %}"
                       aria-label="Primeira">
                        <i class="bi bi-chevron-double-left"></i>
                    </a>
                {% else %}
                    <span class="page-link"><i class="bi bi-chevron-double-left"></i></span>
                {% endif %}
            </li>

            <li class="page-item {{ not pager.hasPreviousPage ? 'disabled' : '' }}">
                {% if pager.hasPreviousPage %}
                    <a class="page-link"
                       href="?{{ pageParam }}={{ pager.previousPage }}{% if queryString %}&{{ queryString }}{% endif %}"
                       aria-label="Anterior">
                        <i class="bi bi-chevron-left"></i>
                    </a>
                {% else %}
                    <span class="page-link"><i class="bi bi-chevron-left"></i></span>
                {% endif %}
            </li>

            {% if startPage > 1 %}
                <li class="page-item disabled">
                    <span class="page-link">…</span>
                </li>
            {% endif %}

            {% for page in startPage..endPage %}
                <li class="page-item {{ page == currentPage ? 'active' : '' }}">
                    {% if page == currentPage %}
                        <span class="page-link">{{ page }}</span>
                    {% else %}
                        <a class="page-link"
                           href="?{{ pageParam }}={{ page }}{% if queryString %}&{{ queryString }}{% endif %}">
                            {{ page }}
                        </a>
                    {% endif %}
                </li>
            {% endfor %}

            {% if endPage < totalPages %}
                <li class="page-item disabled">
                    <span class="page-link">…</span>
                </li>
            {% endif %}

            <li class="page-item {{ not pager.hasNextPage ? 'disabled' : '' }}">
                {% if pager.hasNextPage %}
                    <a class="page-link"
                       href="?{{ pageParam }}={{ pager.nextPage }}{% if queryString %}&{{ queryString }}{% endif %}"
                       aria-label="Próxima">
                        <i class="bi bi-chevron-right"></i>
                    </a>
                {% else %}
                    <span class="page-link"><i class="bi bi-chevron-right"></i></span>
                {% endif %}
            </li>

            <li class="page-item {{ not pager.hasNextPage ? 'disabled' : '' }}">
                {% if pager.hasNextPage %}
                    <a class="page-link"
                       href="?{{ pageParam }}={{ totalPages }}{% if queryString %}&{{ queryString }}{% endif %}"
                       aria-label="Última">
                        <i class="bi bi-chevron-double-right"></i>
                    </a>
                {% else %}
                    <span class="page-link"><i class="bi bi-chevron-double-right"></i></span>
                {% endif %}
            </li>
        </ul>
    </nav>
{% endif %}